# DeepSeek（QuantEngine Research / Risk / Reporter；Live Agent Eval）
DEEPSEEK_API_KEY=sk-your-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
# CI：在 GitHub Actions Secrets 配置同名 DEEPSEEK_API_KEY 以启用 eval-live job

# OpenBB 行情数据源（推荐 FMP 免费 Key，避免 Yahoo 限流）
# 注册: https://financialmodelingprep.com
FMP_API_KEY=your-fmp-api-key

# 可选：强制指定 OpenBB provider（fmp / tiingo / yfinance）
# OPENBB_EQUITY_PROVIDER=fmp

# 可选：其他 OpenBB 数据源
# TIINGO_TOKEN=
# INTRINIO_API_KEY=

# Evidence RAG：SEC EDGAR 披露（默认开启）
EVIDENCE_FETCH_SEC=1
# Episodic Memory 持久化目录（相对项目根）
# EVIDENCE_STORE_DIR=data_cache/evidence
# 每个 symbol 最多保留的 episodic 条数
# EVIDENCE_MAX_EPISODIC=20
# SEC User-Agent（含联系邮箱）
# EVIDENCE_SEC_USER_AGENT=QuantResearchAgentDemo/1.0 (you@example.com)
# Hybrid 检索：tfidf | hybrid | embedding（默认 hybrid）
# EVIDENCE_SEARCH_MODE=hybrid
# Embedding 权重（0~1，hybrid 模式下 embedding 分数占比）
# EVIDENCE_HYBRID_ALPHA=0.45
# Embedding 后端：hashing（默认，离线）| sentence_transformers（需 pip install quant-research-agent[embedding]）
# EVIDENCE_EMBEDDING_BACKEND=hashing
# EVIDENCE_EMBEDDING_MODEL=all-MiniLM-L6-v2
# EVIDENCE_EMBEDDING_DIM=256

# LangGraph Checkpoint（默认 sqlite 持久化；memory=内存；none=关闭）
# LANGGRAPH_CHECKPOINT=sqlite
# 按角色指定模型（未设置则回退 DEEPSEEK_MODEL）
# DEEPSEEK_MODEL_RESEARCH=deepseek-chat
# DEEPSEEK_MODEL_RISK=deepseek-chat
# DEEPSEEK_MODEL_REPORTER=deepseek-chat

# 新闻另类数据（yfinance，默认开启）
# EVIDENCE_FETCH_NEWS=1
# Cross-encoder rerank（需 sentence-transformers）
# EVIDENCE_RERANK_CROSS_ENCODER=0

# HITL：gate.require_human_approval=true 时在 risk 前 interrupt
# 模拟盘
# PAPER_PORTFOLIO_PATH=data_cache/paper/portfolio.json
# PAPER_INITIAL_CASH=100000

# 审计 / trace
# AUDIT_LOG_PATH=data_cache/audit/decisions.jsonl
# AGENT_TRACE_DIR=data_cache/traces
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=

# Agent Eval（scripts/run_eval.py）
# 离线回归无需 API Key；Live 需 DEEPSEEK_API_KEY
# 报告默认：reports/eval_regression_v1.json / reports/eval_capability_v1.json
#           reports/eval_retrieval_v1.json / reports/eval_reliability_v1.json
